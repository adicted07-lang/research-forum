generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === ENUMS ===

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum VoteValue {
  UPVOTE
  DOWNVOTE
}

enum TargetType {
  QUESTION
  ANSWER
  LISTING
  ARTICLE
  COMMENT
}

enum CommentAward {
  INSIGHTFUL
  WELL_RESEARCHED
  HELPFUL
  GOOD_FIND
}

enum UserRole {
  RESEARCHER
  COMPANY
  MODERATOR
  ADMIN
}

enum Availability {
  AVAILABLE
  BUSY
  NOT_AVAILABLE
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_500
  SIZE_500_PLUS
}

enum HiringStatus {
  ACTIVELY_HIRING
  NOT_HIRING
}

enum ListingType {
  SERVICE
  TOOL
}

enum ProjectType {
  ONE_TIME
  ONGOING
  CONTRACT
}

enum LocationPreference {
  REMOTE
  ON_SITE
  HYBRID
}

enum JobStatus {
  OPEN
  FILLED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

// === USER SYSTEM ===

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  username      String?   @unique
  name          String?
  image         String?
  role          UserRole  @default(RESEARCHER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Auth
  accounts Account[]
  sessions Session[]

  // Researcher-specific fields
  banner         String?
  bio            String?
  about          String?
  expertise      String[]
  experienceYears Int?
  hourlyRate     Float?
  availability   Availability?
  portfolioLinks String[]
  socialLinks    Json?
  resumeUrl      String?
  isVerified     Boolean @default(false)
  currency       String  @default("USD")

  // Company-specific fields
  companyName  String?
  companyLogo  String?
  description  String?
  industry     String?
  companySize  CompanySize?
  website      String?
  hiringStatus HiringStatus?

  // Points & Streaks
  points       Int @default(0)
  currentStreak Int @default(0)
  longestStreak Int @default(0)
  lastVisitDate DateTime?

  // Forum relations
  questions  Question[]
  answers    Answer[]
  votes      Vote[]
  comments   Comment[]
  bookmarks  Bookmark[]

  // Social relations
  badges           Badge[]
  following        Follow[]                 @relation("Following")
  followers        Follow[]                 @relation("Followers")
  collections      Collection[]
  notifications    Notification[]
  newsletterSubs   NewsletterSubscription[]

  // Marketplace relations
  listings Listing[]
  reviews  Review[]

  // News relations
  articles Article[] @relation("AuthoredArticles")

  // Hire relations
  companyJobs        Job[]           @relation("CompanyJobs")
  applications       Application[]   @relation("ResearcherApplications")
  threadParticipant1 MessageThread[] @relation("ThreadParticipant1")
  threadParticipant2 MessageThread[] @relation("ThreadParticipant2")
  sentMessages       Message[]       @relation("SentMessages")

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  @@map("tags")
}

// === FORUM MODELS ===

model Question {
  id              String         @id @default(cuid())
  title           String
  body            String         @db.Text
  slug            String         @unique
  tags            String[]
  category        String         @default("General Discussion")
  authorId        String
  upvoteCount     Int            @default(0)
  downvoteCount   Int            @default(0)
  viewCount       Int            @default(0)
  answerCount     Int            @default(0)
  status          QuestionStatus @default(OPEN)
  isPinned        Boolean        @default(false)
  isFeatured      Boolean        @default(false)
  bounty          Int            @default(0)
  bountyExpiresAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  author  User     @relation(fields: [authorId], references: [id])
  answers Answer[]

  @@index([authorId])
  @@index([slug])
  @@index([status])
  @@index([createdAt])
  @@map("questions")
}

model Answer {
  id           String    @id @default(cuid())
  body         String    @db.Text
  authorId     String
  questionId   String
  upvoteCount  Int       @default(0)
  isAccepted   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  author   User     @relation(fields: [authorId], references: [id])
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([questionId])
  @@map("answers")
}

model Vote {
  id         String     @id @default(cuid())
  userId     String
  targetType TargetType
  targetId   String
  value      VoteValue
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("votes")
}

model Comment {
  id          String       @id @default(cuid())
  body        String       @db.Text
  authorId    String
  targetType  TargetType
  targetId    String
  parentId    String?
  upvoteCount Int          @default(0)
  award       CommentAward?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([authorId])
  @@index([targetType, targetId])
  @@index([parentId])
  @@map("comments")
}

model Bookmark {
  id         String     @id @default(cuid())
  userId     String
  targetType TargetType
  targetId   String
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@map("bookmarks")
}

// === SOCIAL MODELS ===

model Badge {
  id        String   @id @default(cuid())
  userId    String
  name      String
  category  String
  earnedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, name])
  @@index([userId])
  @@map("badges")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id])
  following User @relation("Followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id])
  items CollectionItem[]

  @@index([userId])
  @@map("collections")
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  targetType   TargetType
  targetId     String
  createdAt    DateTime   @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, targetType, targetId])
  @@map("collection_items")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  userId    String
  type      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@map("newsletter_subscriptions")
}

// === MARKETPLACE MODELS ===

model Listing {
  id                   String      @id @default(cuid())
  title                String
  tagline              String
  description          String      @db.Text
  slug                 String      @unique
  type                 ListingType
  categoryTags         String[]
  pricingInfo          String?
  mediaGallery         String[]
  websiteUrl           String?
  demoUrl              String?
  authorId             String
  isActive             Boolean     @default(false)
  stripeSubscriptionId String?
  upvoteCount          Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  author User @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([slug])
  @@index([type])
  @@index([isActive])
  @@map("listings")
}

model Review {
  id         String     @id @default(cuid())
  reviewerId String
  targetType TargetType
  targetId   String
  rating     Int
  body       String     @db.Text
  tags       String[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  reviewer User @relation(fields: [reviewerId], references: [id])

  @@unique([reviewerId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("reviews")
}

// === HIRE MODELS ===

model Job {
  id                 String             @id @default(cuid())
  title              String
  description        String             @db.Text
  slug               String             @unique
  researchDomain     String[]
  requiredSkills     String[]
  projectType        ProjectType
  budgetMin          Float?
  budgetMax          Float?
  budgetNegotiable   Boolean            @default(false)
  timeline           String?
  locationPreference LocationPreference @default(REMOTE)
  companyId          String
  applicationsCount  Int                @default(0)
  viewsCount         Int                @default(0)
  status             JobStatus          @default(OPEN)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?

  company      User            @relation("CompanyJobs", fields: [companyId], references: [id])
  applications Application[]
  threads      MessageThread[]

  @@index([companyId])
  @@index([slug])
  @@index([status])
  @@index([createdAt])
  @@map("jobs")
}

model Application {
  id                String            @id @default(cuid())
  jobId             String
  researcherId      String
  coverLetter       String            @db.Text
  proposedRate      Float?
  estimatedTimeline String?
  portfolioLinks    String[]
  status            ApplicationStatus @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  job        Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  researcher User @relation("ResearcherApplications", fields: [researcherId], references: [id])

  @@unique([jobId, researcherId])
  @@index([jobId])
  @@index([researcherId])
  @@map("applications")
}

model MessageThread {
  id           String   @id @default(cuid())
  participant1 String
  participant2 String
  jobId        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user1    User      @relation("ThreadParticipant1", fields: [participant1], references: [id])
  user2    User      @relation("ThreadParticipant2", fields: [participant2], references: [id])
  job      Job?      @relation(fields: [jobId], references: [id])
  messages Message[]

  @@unique([participant1, participant2])
  @@index([participant1])
  @@index([participant2])
  @@map("message_threads")
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("SentMessages", fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// === NEWS MODELS ===

model Article {
  id              String        @id @default(cuid())
  title           String
  body            String        @db.Text
  slug            String        @unique
  authorId        String
  category        String        @default("news")
  coverImage      String?
  readTime        Int?
  tags            String[]
  isFeatured      Boolean       @default(false)
  status          ArticleStatus @default(DRAFT)
  rejectionReason String?
  publishedAt     DateTime?
  sourceUrl       String?
  sourceTitle     String?
  upvoteCount     Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  author User @relation("AuthoredArticles", fields: [authorId], references: [id])

  @@index([authorId])
  @@index([slug])
  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@map("articles")
}

model RSSFeedSource {
  id            String    @id @default(cuid())
  name          String
  url           String    @unique
  pollInterval  Int       @default(3600)
  lastPolledAt  DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@map("rss_feed_sources")
}
