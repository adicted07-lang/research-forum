generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === ENUMS ===

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum VoteValue {
  UPVOTE
  DOWNVOTE
}

enum TargetType {
  QUESTION
  ANSWER
  LISTING
  ARTICLE
  COMMENT
}

enum CommentAward {
  INSIGHTFUL
  WELL_RESEARCHED
  HELPFUL
  GOOD_FIND
}

enum UserRole {
  RESEARCHER
  COMPANY
  MODERATOR
  ADMIN
}

enum Availability {
  AVAILABLE
  BUSY
  NOT_AVAILABLE
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_500
  SIZE_500_PLUS
}

enum HiringStatus {
  ACTIVELY_HIRING
  NOT_HIRING
}

// === USER SYSTEM ===

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  username      String?   @unique
  name          String?
  image         String?
  role          UserRole  @default(RESEARCHER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Auth
  accounts Account[]
  sessions Session[]

  // Researcher-specific fields
  banner         String?
  bio            String?
  about          String?
  expertise      String[]
  experienceYears Int?
  hourlyRate     Float?
  availability   Availability?
  portfolioLinks String[]
  socialLinks    Json?
  resumeUrl      String?
  isVerified     Boolean @default(false)
  currency       String  @default("USD")

  // Company-specific fields
  companyName  String?
  companyLogo  String?
  description  String?
  industry     String?
  companySize  CompanySize?
  website      String?
  hiringStatus HiringStatus?

  // Points & Streaks
  points       Int @default(0)
  currentStreak Int @default(0)
  longestStreak Int @default(0)
  lastVisitDate DateTime?

  // Forum relations
  questions  Question[]
  answers    Answer[]
  votes      Vote[]
  comments   Comment[]
  bookmarks  Bookmark[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  @@map("tags")
}

// === FORUM MODELS ===

model Question {
  id              String         @id @default(cuid())
  title           String
  body            String         @db.Text
  slug            String         @unique
  tags            String[]
  category        String         @default("General Discussion")
  authorId        String
  upvoteCount     Int            @default(0)
  downvoteCount   Int            @default(0)
  viewCount       Int            @default(0)
  answerCount     Int            @default(0)
  status          QuestionStatus @default(OPEN)
  isPinned        Boolean        @default(false)
  isFeatured      Boolean        @default(false)
  bounty          Int            @default(0)
  bountyExpiresAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  author  User     @relation(fields: [authorId], references: [id])
  answers Answer[]

  @@index([authorId])
  @@index([slug])
  @@index([status])
  @@index([createdAt])
  @@map("questions")
}

model Answer {
  id           String    @id @default(cuid())
  body         String    @db.Text
  authorId     String
  questionId   String
  upvoteCount  Int       @default(0)
  isAccepted   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  author   User     @relation(fields: [authorId], references: [id])
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([questionId])
  @@map("answers")
}

model Vote {
  id         String     @id @default(cuid())
  userId     String
  targetType TargetType
  targetId   String
  value      VoteValue
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@map("votes")
}

model Comment {
  id          String       @id @default(cuid())
  body        String       @db.Text
  authorId    String
  targetType  TargetType
  targetId    String
  parentId    String?
  upvoteCount Int          @default(0)
  award       CommentAward?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([authorId])
  @@index([targetType, targetId])
  @@index([parentId])
  @@map("comments")
}

model Bookmark {
  id         String     @id @default(cuid())
  userId     String
  targetType TargetType
  targetId   String
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId])
  @@map("bookmarks")
}
